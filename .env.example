# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# GitHub Configuration
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_DEFAULT_OWNER=YourGitHubUsername
GITHUB_DEFAULT_REPO=YourDefaultRepo

# LLM Provider (choose: "anthropic" or "deepseek")
LLM_PROVIDER=anthropic

# Anthropic API Key (recommended - Haiku/Sonnet/Opus hierarchy)
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# DeepSeek API Key (alternative, cheaper)
# Get key: https://platform.deepseek.com
# DEEPSEEK_API_KEY=sk-your_key_here

# Voice Features (optional)
# OpenAI for TTS (paid but good quality)
# OPENAI_API_KEY=sk-your_key_here

# Groq for STT (free tier, good for transcription)
# GROQ_API_KEY=gsk-your_key_here
