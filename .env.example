# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# GitHub Configuration
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_DEFAULT_OWNER=YourGitHubUsername
GITHUB_DEFAULT_REPO=YourDefaultRepo

# LLM Provider (choose one: "claude" or "deepseek")
LLM_PROVIDER=deepseek

# DeepSeek API Key (free tier available)
# Get key: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your_deepseek_key_here

# Anthropic API Key (for Claude)
# Get key: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# OpenAI API Key (optional, for voice features)
# Get key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your_openai_key_here

# Groq API Key (optional, free alternative for voice)
# Get key: https://console.groq.com/keys
# GROQ_API_KEY=gsk-your_groq_key_here

# Features (optional)
# USE_PLANNER=false  # Enable Extended Thinking planner (requires Anthropic)
